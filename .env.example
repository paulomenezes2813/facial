# =============================================================================
# Facial — variáveis de ambiente (copie para .env e ajuste)
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=facial
POSTGRES_PASSWORD=facial_dev_pwd
POSTGRES_DB=facial
POSTGRES_PORT=5432
DATABASE_URL=postgresql://facial:facial_dev_pwd@localhost:5432/facial?schema=public

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- MinIO (S3 compatível) ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_dev_pwd
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=facial-photos
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio_dev_pwd
S3_REGION=us-east-1

# --- Qdrant (vector DB) ---
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=face_embeddings

# --- Microserviço de reconhecimento (Python) ---
RECOGNITION_PORT=8000
RECOGNITION_URL=http://localhost:8000

# Backend: "insightface" (não-comercial) | "adaface" (comercial OK)
# Trocar exige reindexar todos os embeddings (scripts/reindex_all.py).
FACE_BACKEND=insightface
ADAFACE_MODEL_PATH=/app/models/adaface_ir101_webface4m.onnx

INSIGHTFACE_MODEL=buffalo_l
INSIGHTFACE_DET_SIZE=640

# 0.45 calibrado pra ArcFace; AdaFace usa ~0.35.
MATCH_THRESHOLD=0.45

# --- API (NestJS) ---
API_PORT=3001
API_URL=http://localhost:3001
JWT_SECRET=change-me-in-production-very-long-random-string

# --- Web (Next.js) ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Admin inicial (usado pelo seed) ---
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador

# --- Política de retenção (LGPD) ---
RETENTION_DAYS=10
